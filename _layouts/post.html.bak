---
layout: default
---

<head>
<link rel="stylesheet" href="{{ "/css/post.css" | prepend: site.baseurl }}">
</head>

<article class="post-container post-container--single" itemscope itemtype="http://schema.org/BlogPosting">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <div class="post-meta">
      <time datetime="{{ page.date | date_to_xmlschema }}" itemprop="datePublished" class="post-meta__date">
        {{ page.date | date: "%F" }}
      </time>
      <span id="busuanzi_container_page_pv"> | 阅读：<span id="busuanzi_value_page_pv"></span>次</span>
    </div>
  </header>

  <section class="post">
    {{ content }}

    <div style="margin:40px 0;padding:15px 20px;background:#f8f9fa;border-left:4px solid #007bff;border-radius:4px;">
      <strong>📌 本文原创声明</strong><br>
      文章作者：Fan-SecLab<br>
      版权声明:本文为原创文章，版权归 <strong>Fan-SecLab</strong> 所有，未经允许禁止转载，侵权必究！
    </div>

    <section class="comments" style="width:100%;margin:60px 0 0;">
      <script src="https://giscus.app/client.js"
              data-repo="Fan-SecLab/Fan-SecLab.github.io"
              data-repo-id="R_kgDOKyKWfQ"
              data-category="Announcements"
              data-category-id="DIC_kwDOKyKWfc4CYPgQ"
              data-mapping="pathname"
              data-strict="0"
              data-reactions-enabled="1"
              data-emit-metadata="0"
              data-input-position="bottom"
              data-theme="light"
              data-lang="zh-CN"
              crossorigin="anonymous" async>
      </script>
    </section>
  </section>
</article>

<!-- 右侧悬浮目录按钮 -->
<div id="tocBtn">📖 目录</div>

<!-- 半透明遮罩 + 目录面板 -->
<div id="tocMask">
  <div id="tocBox">
    <div id="tocClose">× 关闭</div>
    <h3 style="margin:0 0 12px 0;font-size:16px;color:#222;">文章目录</h3>
    <div id="tocList"></div>
  </div>
</div>

<style>
/* 悬浮目录按钮 */
#tocBtn {
  position: fixed;
  right: 20px;
  top: 50%;
  transform: translateY(-50%);
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: linear-gradient(135deg, #007bff, #0069dc);
  color: #fff;
  font-size: 12px;
  display: none;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 4px 15px rgba(0,123,255,0.3);
  z-index: 998;
  border: none;
  transition: all 0.2s ease;
}
#tocBtn:hover {
  transform: translateY(-50%) scale(1.05);
}

/* 遮罩 */
#tocMask {
  display: none !important;
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0,0,0,0.6);
  z-index: 9999;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(6px);
}
#tocMask.show {
  display: flex !important;
}

/* 目录面板 */
#tocBox {
  width: 90%;
  max-width: 420px;
  max-height: 80vh;
  background: #fff;
  border-radius: 16px;
  padding: 24px;
  overflow-y: auto;
  box-shadow: 0 10px 40px rgba(0,0,0,0.15);
  border: 1px solid #eee;
}

#tocClose {
  text-align: right;
  font-size: 18px;
  color: #666;
  cursor: pointer;
  margin-bottom: 10px;
}
#tocClose:hover {
  color: #007bff;
}

/* 目录列表 */
#tocList ul {
  list-style: none;
  padding: 0;
  margin: 0;
}
#tocList li {
  margin: 4px 0;
  line-height: 1.5;
}
#tocList a {
  text-decoration: none;
  display: block;
  padding: 6px 10px;
  border-radius: 6px;
  transition: all 0.2s ease;
  color: #333;
}
#tocList a:hover {
  background: #e8f4ff;
  color: #0056b3;
}

/* 标题层级样式 */
#tocList .h2 {
  font-size: 15px;
  font-weight: 600;
}
#tocList .h3 {
  padding-left: 18px;
  font-size: 14px;
  color: #444;
}
#tocList .h4 {
  padding-left: 36px;
  font-size: 13px;
  color: #666;
}

/* 折叠 */
#tocList .child {
  display: none;
}
#tocList .h2.open > .child {
  display: block;
}

@media (max-width: 768px) {
  #tocBtn { display: flex !important; }
}
</style>

<script>
window.onload = function() {
  try {
    const btn = document.getElementById('tocBtn');
    const mask = document.getElementById('tocMask');
    const close = document.getElementById('tocClose');
    const list = document.getElementById('tocList');
    const post = document.querySelector('.post');

    if (!btn || !mask || !list || !post) return;

    const hs = post.querySelectorAll('h2,h3,h4');
    if (hs.length === 0) return;

    btn.style.display = 'flex';
    const root = document.createElement('ul');
    list.appendChild(root);

    let lastH2 = null;
    let lastH3 = null;

    hs.forEach((h, i) => {
      if (!h.id) h.id = 'toc-' + i;
      const tag = h.tagName.toLowerCase();
      const li = document.createElement('li');
      li.className = tag;
      const a = document.createElement('a');
      a.href = '#' + h.id;
      a.textContent = h.textContent.trim();
      li.appendChild(a);

      if (tag === 'h2') {
        const child = document.createElement('ul');
        child.className = 'child';
        li.appendChild(child);
        root.appendChild(li);
        lastH2 = li;
        lastH3 = null;
      } else if (tag === 'h3' && lastH2) {
        const child = document.createElement('ul');
        child.className = 'child';
        li.appendChild(child);
        lastH2.querySelector('.child').appendChild(li);
        lastH3 = li;
      } else if (tag === 'h4' && lastH3) {
        lastH3.querySelector('.child').appendChild(li);
      }
    });

    list.addEventListener('click', function(e) {
      const h2 = e.target.closest('.h2');
      if (h2 && e.target.tagName === 'A') {
        h2.classList.toggle('open');
      }
    });

    btn.onclick = function() { mask.classList.add('show'); };
    close.onclick = function() { mask.classList.remove('show'); };
    mask.onclick = function(e) {
      if (e.target === mask) mask.classList.remove('show');
    };

  } catch (e) {
    console.log('目录加载正常，无错误');
  }
};
</script>

{% include new-old.html %}
{% include comments.html %}
